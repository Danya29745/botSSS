# ── Обязательные переменные ──────────────────────────────
BOT_TOKEN=ваш_токен_от_BotFather

# Telegram ID администраторов через запятую (без пробелов)
ADMIN_IDS=123456789,987654321

# ── База данных ───────────────────────────────────────────
# SQLite (по умолчанию, не менять если не нужен PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///halvex.db

# PostgreSQL (опционально, раскомментировать для продакшна)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/halvex_db

# ── Реферальная система ───────────────────────────────────
REFERRAL_BONUS_REFERRER=50
REFERRAL_BONUS_NEW_USER=30

# ── 3x-UI панель (заполнить позже) ───────────────────────
XUI_HOST=https://ваш-сервер:2053
XUI_USERNAME=admin
XUI_PASSWORD=ваш_пароль

# ── Платёжная система (заполнить позже) ──────────────────
PAYMENT_TOKEN=
